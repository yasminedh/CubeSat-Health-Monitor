import 'package:flutter/material.dart';
import 'package:mqtt_client/mqtt_client.dart';
import 'package:mqtt_client/mqtt_server_client.dart';

class DashboardPage extends StatelessWidget {

  final MqttServerClient client;

  const DashboardPage({
    super.key,
    required this.client,
  });

  @override
  Widget build(BuildContext context) {

    // fake data (sera remplacé par MQTT plus tard)
    double temp = 24.5;
    double pressure = 1012.3;
    double altitude = 120.0;
    int battery = 78;
    String mode = "NOMINAL";

    // ✅ SAFE MQTT STATUS
    final isConnected =
        client.connectionStatus?.state == MqttConnectionState.connected;

    final mqttState =
        client.connectionStatus?.state.toString() ?? "UNKNOWN";

    return Scaffold(
      backgroundColor: const Color(0xFF060C1A),

      appBar: AppBar(
        title: const Text("Mission Control"),
        centerTitle: true,
        backgroundColor: Colors.black,
      ),

      body: SingleChildScrollView(
        padding: const EdgeInsets.all(16),
        child: Column(
          children: [

            // MQTT STATUS DEBUG (FIXED)
            Container(
              width: double.infinity,
              padding: const EdgeInsets.all(10),
              decoration: BoxDecoration(
                color: isConnected ? Colors.green : Colors.red,
                borderRadius: BorderRadius.circular(10),
              ),
              child: Text(
                "MQTT: $mqttState",
                textAlign: TextAlign.center,
                style: const TextStyle(
                  color: Colors.white,
                  fontWeight: FontWeight.bold,
                ),
              ),
            ),

            const SizedBox(height: 20),

            // STATUS BAR
            Container(
              width: double.infinity,
              padding: const EdgeInsets.all(12),
              decoration: BoxDecoration(
                color: mode == "NOMINAL"
                    ? Colors.green
                    : Colors.orange,
                borderRadius: BorderRadius.circular(12),
              ),
              child: Text(
                "MODE: $mode",
                textAlign: TextAlign.center,
                style: const TextStyle(
                  color: Colors.white,
                  fontSize: 18,
                  fontWeight: FontWeight.bold,
                ),
              ),
            ),

            const SizedBox(height: 20),

            // TELEMETRY GRID
            GridView.count(
              crossAxisCount: 2,
              shrinkWrap: true,
              physics: const NeverScrollableScrollPhysics(),
              crossAxisSpacing: 10,
              mainAxisSpacing: 10,
              children: [

                _card("Temperature", "$temp °C", Icons.thermostat),
                _card("Pressure", "$pressure hPa", Icons.compress),
                _card("Altitude", "$altitude m", Icons.height),
                _card("Battery", "$battery %", Icons.battery_full),

              ],
            ),

            const SizedBox(height: 20),

            _sectionTitle("Mission Timeline"),

            _log("BOOT COMPLETE"),
            _log("MQTT CONNECTED"),
            _log("NOMINAL MODE ACTIVE"),

            const SizedBox(height: 20),

            _sectionTitle("Alerts"),

            _alert("NO CRITICAL EVENTS"),

            const SizedBox(height: 20),

            _sectionTitle("Commands"),

            Wrap(
              spacing: 10,
              children: [
                _btn("SAFE MODE"),
                _btn("RESET"),
                _btn("PING"),
              ],
            ),
          ],
        ),
      ),
    );
  }

  Widget _card(String title, String value, IconData icon) {
    return Card(
      child: Padding(
        padding: const EdgeInsets.all(12),
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(icon, size: 35),
            const SizedBox(height: 10),
            Text(title),
            const SizedBox(height: 5),
            Text(
              value,
              style: const TextStyle(
                fontSize: 18,
                fontWeight: FontWeight.bold,
              ),
            )
          ],
        ),
      ),
    );
  }

  Widget _sectionTitle(String text) {
    return Align(
      alignment: Alignment.centerLeft,
      child: Text(
        text,
        style: const TextStyle(
          fontSize: 18,
          fontWeight: FontWeight.bold,
        ),
      ),
    );
  }

  Widget _log(String text) {
    return ListTile(
      leading: const Icon(Icons.timeline),
      title: Text(text),
    );
  }

  Widget _alert(String text) {
    return ListTile(
      leading: const Icon(Icons.warning, color: Colors.orange),
      title: Text(text),
    );
  }

  Widget _btn(String text) {
    return ElevatedButton(
      onPressed: () {},
      child: Text(text),
    );
  }
}
